# Aipany Realtime Gateway
PORT=3000
HOST=0.0.0.0
AIPANY_GATEWAY_TOKEN=

# 阿里云百炼（ASR/TTS 共用）
DASHSCOPE_API_KEY=sk-xxx
DASHSCOPE_WORKSPACE_ID=
DASHSCOPE_ASR_WS_BASE_URL=
DASHSCOPE_TTS_WS_BASE_URL=

# 千问实时 ASR
QWEN_ASR_MODEL=qwen3-asr-flash-realtime
QWEN_ASR_LANGUAGE=zh
QWEN_ASR_VAD_THRESHOLD=0.0
QWEN_ASR_SILENCE_MS=500

# 千问实时 TTS
# 默认选择支持 instructions 的实时模型，便于情绪/语气控制。
QWEN_TTS_MODEL=qwen3-tts-instruct-flash-realtime
QWEN_TTS_VOICE=Cherry
QWEN_TTS_LANGUAGE=Chinese
QWEN_TTS_SAMPLE_RATE=24000
QWEN_TTS_OPTIMIZE_INSTRUCTIONS=false

# OpenAI 兼容中转站 LLM
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-5.6-sol
LLM_TEMPERATURE=0.8
LLM_MAX_TOKENS=800

# 会话
MAX_HISTORY_MESSAGES=20
DEFAULT_SYSTEM_PROMPT=你是一个自然、温暖、有陪伴感的中文语音助手。回答适合直接说出口，优先简洁、口语化。可以自然使用“嗯”“诶”“哎呀”“哈哈”等语气词，但不要刻意堆砌。不要输出舞台说明、Markdown 或情绪标签。
