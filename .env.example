# Aipany Realtime Gateway
PORT=3000
HOST=0.0.0.0

# 服务端 API 配置管理页
# 生产部署时请生成随机 Token，例如：openssl rand -hex 32
AIPANY_ADMIN_TOKEN=
AIPANY_RUNTIME_CONFIG_PATH=/data/runtime-api-config.json

# 鉴权：生产环境推荐 JWT；AIPANY_GATEWAY_TOKEN 仅保留旧客户端兼容。
AIPANY_GATEWAY_TOKEN=
AIPANY_JWT_SECRET=
AIPANY_JWT_ISSUER=
AIPANY_JWT_AUDIENCE=
AIPANY_ALLOW_ANONYMOUS=false

# Android 预览客户端：开启后可给 App 自动签发仅含 realtime 权限的短期 JWT。
# 正式账号系统上线后应关闭该模式。
AIPANY_MOBILE_PREVIEW_ENABLED=false
AIPANY_MOBILE_PREVIEW_TOKEN_TTL_SECONDS=21600
AIPANY_MOBILE_PREVIEW_TENANT=mobile-preview

# 下列 API 配置可保持为空，服务启动后在 /admin/config 页面填写。
# 阿里云百炼（ASR/TTS/Omni 可共用）
DASHSCOPE_API_KEY=
DASHSCOPE_WORKSPACE_ID=
DASHSCOPE_ASR_WS_BASE_URL=
DASHSCOPE_TTS_WS_BASE_URL=

# 千问实时 ASR
QWEN_ASR_MODEL=qwen3-asr-flash-realtime
QWEN_ASR_LANGUAGE=zh
QWEN_ASR_VAD_THRESHOLD=0.0
QWEN_ASR_SILENCE_MS=500

# 千问实时 TTS
QWEN_TTS_MODEL=qwen3-tts-instruct-flash-realtime
QWEN_TTS_VOICE=Cherry
QWEN_TTS_LANGUAGE=Chinese
QWEN_TTS_SAMPLE_RATE=24000
QWEN_TTS_OPTIMIZE_INSTRUCTIONS=false

# OpenAI 兼容 Text LLM
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-5.6-sol
LLM_TEMPERATURE=0.8
LLM_MAX_TOKENS=800

# Local Realtime Audio Intelligence：ECAPA + 轻量 Diarization
SPEAKER_INTELLIGENCE_ENABLED=true
SPEAKER_INTELLIGENCE_BASE_URL=http://speaker-intelligence:3200
SPEAKER_INTELLIGENCE_TOKEN=
SPEAKER_SERVICE_TOKEN=
SPEAKER_INTELLIGENCE_TIMEOUT_MS=2500
SPEAKER_INTELLIGENCE_ANALYSIS_TIMEOUT_MS=20000
SPEAKER_MIN_AUDIO_MS=700
SPEAKER_PRE_ROLL_MS=350
SPEAKER_ANALYSIS_WAIT_MS=700
GROUP_ANALYSIS_WAIT_MS=3500
SPEAKER_SESSION_MATCH_THRESHOLD=0.76

# Gateway 请求能力开关。v0.4 可由 Cloud/Remote Provider 满足，不代表本地加载重模型。
AUDIO_DIARIZATION_ENABLED=true
AUDIO_SEPARATION_ENABLED=true
AUDIO_ENVIRONMENT_ENABLED=true
AUDIO_SEGMENT_TRANSCRIPTION_ENABLED=true
TARGET_SPEAKER_MIN_CONFIDENCE=0.62

# Cloud Intelligence：Qwen Omni 环境理解 + 云端分说话人转写
CLOUD_AUDIO_INTELLIGENCE_ENABLED=true
CLOUD_AUDIO_ENVIRONMENT_ENABLED=true
CLOUD_AUDIO_DIARIZED_TRANSCRIPTION_ENABLED=true
CLOUD_AUDIO_TIMEOUT_MS=30000
# 留空时复用 DASHSCOPE_API_KEY；Base URL 留空时按 DASHSCOPE_WORKSPACE_ID 自动生成北京地域地址。
QWEN_OMNI_API_KEY=
QWEN_OMNI_BASE_URL=
QWEN_OMNI_MODEL=qwen3.5-omni-flash

# Remote GPU：兼容 Aipany /v1/analyze 协议的 SepFormer Worker
# 低配服务器首次部署可先 false；准备好远程 GPU Worker 后可在 /admin/config 页面启用。
REMOTE_SEPARATION_ENABLED=false
REMOTE_SEPARATION_BASE_URL=
REMOTE_SEPARATION_TOKEN=
REMOTE_SEPARATION_TIMEOUT_MS=30000
# overlap_only / overlap_or_multi_speaker / always_owner_focus
REMOTE_SEPARATION_TRIGGER=overlap_or_multi_speaker

# 服务端 Audio Front-End
AUDIO_FRONTEND_ENABLED=true
AUDIO_AEC_ENABLED=true
AUDIO_NOISE_SUPPRESSION_ENABLED=true
AUDIO_AGC_ENABLED=true
AUDIO_DEREVERB_ENABLED=true
AUDIO_BEAMFORMING_ENABLED=true
AUDIO_AEC_DELAY_MS=120
AUDIO_AGC_TARGET_DBFS=-20
AUDIO_AGC_MAX_GAIN=6
AUDIO_FRONTEND_METRICS_INTERVAL_MS=5000

# Speaker Identity Persistence
SPEAKER_IDENTITY_STORE=memory
DATABASE_URL=postgresql://aipany:aipany-dev-change-me@postgres:5432/aipany
SPEAKER_IDENTITY_DATABASE_SSL=false
SPEAKER_IDENTITY_DB_POOL_MAX=10
SPEAKER_IDENTITY_MATCH_CANDIDATES=20
SPEAKER_CONSENT_REQUIRED=true

# 单密钥兼容格式：openssl rand -base64 32
SPEAKER_IDENTITY_ENCRYPTION_KEY=
# Keyring 轮换格式示例：{"active":"v2","search":"<stable-search-key>","keys":{"v2":"<new-key>","v1":"<old-key>"}}
# 先把新 key 设为 active，再运行：npm --workspace @aipany/realtime-gateway run speaker:rotate-keys

# Docker Compose PostgreSQL
POSTGRES_PASSWORD=aipany-dev-change-me

# Local Speaker Intelligence 模型服务
SPEAKER_MODEL_SOURCE=speechbrain/spkrec-ecapa-voxceleb
SPEAKER_MODEL_CACHE_DIR=/models/speechbrain/spkrec-ecapa-voxceleb
SPEAKER_DEVICE=cpu
SPEAKER_SERVICE_MIN_AUDIO_MS=500
DIARIZATION_ENABLED=true
DIARIZATION_WINDOW_MS=1400
DIARIZATION_HOP_MS=700
DIARIZATION_MATCH_THRESHOLD=0.72
DIARIZATION_MIN_REGION_MS=320
DIARIZATION_MAX_SPEAKERS=8

# v0.4 默认把三个重型能力迁出低配本机。
SPEECH_SEPARATION_ENABLED=false
SEPARATION_MODEL_SOURCE=speechbrain/sepformer-wsj02mix
SEPARATION_MODEL_CACHE_DIR=/models/speechbrain/sepformer-wsj02mix
SEPARATION_SECOND_SOURCE_RATIO=0.12
SEPARATION_DISTINCT_SPEAKER_THRESHOLD=0.78
TARGET_SPEAKER_EXTRACTION_ENABLED=false
TARGET_SPEAKER_THRESHOLD=0.72

SEGMENT_TRANSCRIPTION_ENABLED=false
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_MODEL_CACHE_DIR=/models/faster-whisper

ENVIRONMENT_INTELLIGENCE_ENABLED=false
ENVIRONMENT_MODEL_SOURCE=MIT/ast-finetuned-audioset-10-10-0.4593
ENVIRONMENT_MODEL_CACHE_DIR=/models/huggingface

# Social Conversation Manager
SOCIAL_DECISION_ENABLED=true

# 会话
MAX_HISTORY_MESSAGES=20
DEFAULT_SYSTEM_PROMPT=你是一个自然、温暖、有陪伴感的中文语音助手。回答适合直接说出口，优先简洁、口语化。可以自然使用“嗯”“诶”“哎呀”“哈哈”等语气词，但不要刻意堆砌。不要输出舞台说明、Markdown 或情绪标签。
