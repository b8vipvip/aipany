  },
  "dependencies": {
    "@aipany/audio-intelligence": "0.4.0",
    "@aipany/protocol": "0.3.1",
    "ws": "^8.18.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
