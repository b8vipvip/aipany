{
  "name": "@aipany/realtime-gateway",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "speaker:rotate-keys": "node dist/tools/rotate-speaker-identity-keys.js",
    "test": "node --import tsx --test test/**/*.test.ts",
