{
  "expo": {
    "name": "Aipany",
    "slug": "aipany",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "plugins": [
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      "@config-plugins/react-native-webrtc"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Aipany 需要使用麦克风与 AI 进行实时语音对话。"
      }
    },
    "android": {
      "permissions": ["RECORD_AUDIO", "MODIFY_AUDIO_SETTINGS"],
      "package": "com.aipany.mobile"
    },
    "extra": {
      "apiBaseUrl": "http://localhost:3000"
    }
  }
}
